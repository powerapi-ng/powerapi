{
  "verbose": true,
  "stream": true,
  "input": {
    "hwpcsensor": {
      "model": "HWPCReport",
      "type": "socket",
      "host": "localhost",
      "port": 8889
    }
  },
  "output": {
    "powerrep1": {
      "type": "json",
      "model": "PowerReport",
      "filepath": "/tmp/pytest-powerrep.jsonl",
      "compression": "none"
    },
    "powerrep2": {
      "type": "csv",
      "model": "PowerReport",
      "directory": "/tmp/powerapi-csv-export-test"
    },
    "formularep": {
      "type": "json",
      "model": "FormulaReport",
      "filepath": "/tmp/pytest-formularep.jsonl",
      "compression": "none"
    }
  }
}
