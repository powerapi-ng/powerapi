{
  "verbose": true,
  "stream": true,
  "input": {
      "one_puller": {
          "model": "HWPCReport",
          "type": "socket",
          "host": "localhost",
          "port": 8889
      }
  },
  "output": {
      "one_pusher": {
          "type": "json",
          "model": "PowerReport",
          "filepath": "/tmp/pytest-powerapi-powerrep.jsonl"
      }
  },
  "pre-processor": {
      "my_processor": {
          "type": "k8s",
          "api-mode": "manual",
          "puller": "one_puller"
      }
  }
}
